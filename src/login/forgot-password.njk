---
title: Regenerate Skagit Profile
layout: layouts/default.njk

permalink: "/login/forgot-password/"
---
<div x-data="authApp()" class="bg-white p-8 rounded-xl shadow-md w-full max-w-md mx-auto mt-12">

  <h1 class="text-2xl font-bold mb-4 text-center">Forgot Password</h1>

  <form x-show="!$store.auth.user" @submit.prevent="forgotPassword" class="mb-6">
    <h2 class="font-semibold mb-2">Reset Your Password</h2>
    <p class="mb-4 text-gray-600">
      Enter your email address below, and we'll send you instructions to reset your password.
    </p>
    <input
      type="email"
      x-model="forgot.email"
      placeholder="Email Address"
      class="w-full mb-4 p-2 border rounded"
    >
    <button type="submit" class="w-full bg-green-600 text-white p-2 rounded hover:bg-green-700">
      Send Reset Instructions
    </button>
  </form>
</div>

<script>
function authApp() {
  return {
    forgot: {
      email: ''
    },

    async forgotPassword() {
      try {
        await Alpine.store("api").call("reset_password_token", {}, {
          username: this.forgot.email
        });

        alert("Password reset instructions sent.");
      } catch (e) {
        console.error("Reset failed:", e);
        alert("Could not send reset email. Try again.");
      } finally {
        this.forgot.email = '';
      }
    }
  }
}
</script>
