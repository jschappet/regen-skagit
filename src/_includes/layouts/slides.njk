<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title | default("Slideshow") }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Reveal.js CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/reveal.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/theme/moon.css">
  <style>
    /* in your Reveal.js custom CSS */

    .reveal {
  color: #ffffff;
}

.reveal section img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover; /* fills frame, crops overflow */
  display: block;
}

.reveal h1,
.reveal h2, 
.reveal h3,
.reveal h4,
.reveal p {
  color: #ffffff;
  text-shadow: 0 5px 10px rgba(10,10,0,0.9);
}

 p {
  color: #000000;
  text-shadow: 0 5px 10px rgba(0,0,0,0.9);
}
.overlay-slide::before {
  content: "";
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.8); /* black overlay at 40% opacity */
  z-index: 1;
}

.reveal section.overlay-slide > * {
  position: relative;
  z-index: 2;
}
</style>
</head>
<body>

<div class="reveal">
  <div class="slides">
    <!-- Insert Markdown content from page -->
    <section data-markdown="{{ src_file_name | url }}" 
        data-separator="^---$" 
        data-markdown-preset="marked">
    </section>
  </div>
</div>

<!-- Reveal.js Scripts -->
<script src="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/reveal.js"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/plugin/markdown/markdown.js"></script>
<script>
  Reveal.initialize({
    margin: 0.4,
    hash: true,
    slideNumber: true,
    overview: true,
    plugins: [ RevealMarkdown ]
  });
</script>

</body>
</html>
