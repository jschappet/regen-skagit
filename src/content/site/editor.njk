---
title: Editor Guide
permalink: /editor/

---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Skagit JSON Editor</title>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background: #f5f5f4;
      margin: 0;
      padding: 1.5rem;
      color: #222;
    }

    h1 { font-size: 1.5rem; margin-bottom: 1rem; }

    .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      height: calc(100vh - 10rem);
    }

    .editor, .preview {
      background: #fff;
      border-radius: 8px;
      padding: 1rem;
      overflow: auto;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }

    .item {
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 0.75rem;
      margin-bottom: 0.75rem;
      background: #fafafa;
      cursor: grab;
    }

    .field { display: flex; flex-direction: column; margin-bottom: 0.5rem; }
    .field label { font-size: 0.75rem; color: #555; margin-bottom: 0.25rem; }
    .field input, .field textarea, .field select {
      font-size: 0.85rem; padding: 0.4rem; border-radius: 4px; border: 1px solid #ccc;
    }

    pre {
      font-size: 0.75rem;
      white-space: pre-wrap;
      word-break: break-word;
      background: #0f172a;
      color: #e5e7eb;
      padding: 0.75rem;
      border-radius: 6px;
    }

    button {
      margin-top: 0.5rem;
      padding: 0.4rem 0.6rem;
      font-size: 0.75rem;
      border-radius: 4px;
      border: none;
      background: #334155;
      color: white;
      cursor: pointer;
    }

    button.secondary { background: #94a3b8; }
  </style>
</head>
<body x-data="editor()">

  <h1>Skagit Section JSON Editor</h1>

  <div style="margin-bottom:1rem;">
    <label style="font-size:0.8rem;color:#555;">Paste JSON</label>
    <textarea x-model="rawJson" rows="6" style="width:100%;font-size:0.75rem;padding:0.5rem;border-radius:6px;border:1px solid #ccc;"></textarea>
    <button @click="loadJson">Load JSON</button>
  </div>

  <div class="container">
    <div class="editor">
      <template x-for="(item, index) in sorted" :key="index">
        <div class="item">
          <div class="field">
            <label>Title</label>
            <input x-model="item.title" />
          </div>

          <div class="field">
            <label>Description</label>
            <textarea rows="3" x-model="item.description"></textarea>
          </div>

          <div class="field">
            <label>Format</label>
            <select x-model="item.format">
              <option value="">—</option>
              <option value="aside">aside</option>
              <option value="bullets">bullets</option>
              <option value="centered">centered</option>
              <option value="left">left</option>
              <option value="triptych">triptych</option>
              <option value="twoimages">twoimages</option>
            </select>
          </div>

          <div class="field">
            <label>Image</label>
            <input x-model="item.image" />
          </div>

          <button class="secondary" @click="remove(index)">Remove</button>
        </div>
      </template>
    </div>

    <div class="preview">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
        <h2 style="font-size:1rem;margin-top:0">Live JSON</h2>
        <button @click="copy">Copy</button>
      </div>
      <pre x-text="json"></pre>
    </div>
  </div>

<script>
function editor() {
  return {
    data: [],
    rawJson: '',

    get sorted() {
      return this.data.sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
    },

    get json() {
      return JSON.stringify(this.data, null, 2);
    },

    loadJson() {
      try {
        const parsed = JSON.parse(this.rawJson);
        if (!Array.isArray(parsed)) throw new Error();
        this.data = parsed;
      } catch {
        alert('Invalid JSON');
      }
    },

    remove(index) {
      this.data.splice(index, 1);
    },

    copy() {
      navigator.clipboard.writeText(this.json);
    }
  }
}
</script>

</body>
</html>
