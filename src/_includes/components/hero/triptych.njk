{% extends "components/hero/base.njk" %}

{% block heroContent %}

  <div class="max-w-6xl mx-auto">

    <!-- Narrative -->
    <div class="mb-12 max-w-3xl">
      <h2 class="hero-title" data-aos="fade-up" data-aos-delay="100">
        {{ heroData.title }}
      </h2>
      <p class="hero-body" data-aos="fade-up" data-aos-delay="200">
        {{ heroData.description }}
      </p>
    </div>

    {% if heroData.panels %}
      <!-- Image Triptych -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6" data-aos="fade-up" data-aos-delay="300">
        {% for panel in heroData.panels %}
          {% if panel.image %}
            <div class="aspect-4/3 overflow-hidden rounded-xl shadow-lg">
              {{ imageHtml[panel.image.src] | safe }}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Optional captions -->
      <div class="grid gap-6 grid-cols-[repeat(auto-fit,minmax(260px,1fr))]">
        {% for panel in heroData.panels %}
          <div>
            {% if panel.title %}
              <h3 class="text-xl font-semibold text-green-dark mb-2">
                {{ panel.title }}
              </h3>
            {% endif %}
            {% if panel.text %}
              <p class="text-base leading-relaxed text-gray-700">
                {{ panel.text }}
              </p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>

{% endblock %}
