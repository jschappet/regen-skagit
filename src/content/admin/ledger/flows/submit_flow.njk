---
title: "Submit new flow"
permalink: "/admin/ledger/submit_flow/"
layout: "layouts/admin.njk"
---
<div x-data="flowForm()" class="max-w-xl mx-auto p-6 bg-white shadow-lg rounded-xl">

    <form @submit.prevent="submit" class="space-y-5">

        <h2 class="text-xl font-semibold text-gray-800">Record Flow</h2>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Resource Type
            </label>
            <select
                x-model="form.resource_type" @change="form.quantity_unit = units[0]"
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            >
                <option value="Hours">Hours</option>
                <option value="Meals">Meals</option>
                <option value="Dollars">Dollars</option>
                <option value="Plants">Plants</option>
                <option value="Tools">Tools</option>
            </select>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Quantity
            </label>
            <input
                type="number"
                step="0.01"
                x-model.number="form.quantity_value"
                required
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            >
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Unit</label>

            <select
    x-model="form.quantity_unit"
    class="w-full border border-gray-300 rounded-lg px-3 py-2 bg-white focus:ring-2 focus:ring-green-500"
  >
                <template x-for="unit in units" :key="unit">
                    <option :value="unit" x-text="unit"></option>
                </template>
            </select>

        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                From Entity
            </label>
            <input
                type="text"
                x-model="form.from_entity"
                placeholder="entity uuid or slug"
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            >
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                To Entity
            </label>
            <input
                type="text"
                x-model="form.to_entity"
                placeholder="entity uuid or slug"
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            >
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Timestamp
            </label>
            <input
                type="datetime-local"
                x-model="form.timestamp"
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            >
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
                Notes
            </label>
            <textarea
                x-model="form.notes"
                rows="3"
                class="w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
            ></textarea>
        </div>

        <button
            type="submit"
            class="w-full bg-indigo-600 text-white font-medium py-2 px-4 rounded-md hover:bg-indigo-700 transition"
        >
            Record Flow
        </button>

        <div
            x-show="status"
            x-text="status"
            class="text-sm text-gray-600 mt-2"
        ></div>

    </form>

</div>

<script>
    function flowForm() {
        return {
            resourceUnits: {
                Hours: ["hours"],
                Meals: ["meals"],
                Dollars: ["USD"],
                Plants: ["plants"],
                Tools: ["tools"],
                Product: ["count"]
            },
            form: {
                resource_type: "Hours",
                quantity_value: 0,
                quantity_unit: "",
                from_entity: "",
                to_entity: "",
                timestamp: "",
                notes: ""
            },

            status: "",
            get units() {
                return this.resourceUnits[this.form.resource_type] || [];
            },
            async submit() {

                try {

                    const cleanedForm = Object.fromEntries(Object.entries(this.form).filter(([_, v]) => v !== ""));
                    if (cleanedForm.timestamp) {
                        cleanedForm.timestamp = cleanedForm.timestamp.length === 16
                            ? cleanedForm.timestamp + ":00"
                            : cleanedForm.timestamp;

                    }

                    const entity = await Alpine
                        .store("api")
                        .call("submit_flow", {}, cleanedForm);

                    this.status = "Flow recorded ✔"
                    this.form.quantity_value = ""
                    this.form.notes = ""

                    //this.entities.push(entity);
                    //this.newEntity.name = '';
                    //this.newEntity.entity_type = '';
                } catch (e) {
                    console.error('Failed to create submit flow', e);
                }

            }

        }
    }
</script>